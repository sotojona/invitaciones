<div class="container" id="container">
  <div class="envelope" id="envelope">
    <div class="flap"></div>
    <div class="body"></div>
  </div>

  <!-- Invitación dentro del sobre (oculta hasta abrir) -->
  <div class="invitation">
    <p>¡Nos casamos!</p>
    <p>17 de octubre de 2026</p>
  </div>
</div>

<style>
.container {
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f4efe6;
  transition: opacity 1s ease;
  position: relative;
}

.envelope {
  position: relative;
  width: 320px;
  height: 210px;
  cursor: pointer;
  perspective: 1200px;
  z-index: 2;
}

.body {
  width: 100%;
  height: 100%;
  background-color: #f0e5d6; /* color más elegante tipo papel */
  border-radius: 10px;
  box-shadow: 0 6px 15px rgba(0,0,0,0.2); /* sombra 3D */
  position: relative;
  z-index: 1;
}

.flap {
  position: absolute;
  top: 0;
  width: 100%;
  height: 110px;
  background-color: #e4d6ba; /* ligeramente más oscuro */
  transform-origin: top;
  transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  clip-path: polygon(0 0, 100% 0, 50% 100%);
  box-shadow: inset 0 -4px 6px rgba(0,0,0,0.1);
  z-index: 2;
}

.envelope.open .flap {
  transform: rotateX(180deg);
}

/* Invitación dentro del sobre */
.invitation {
  position: absolute;
  top: 50%;
  right: 0%;
  transform: translateY(-50%) translateX(140px) scale(1);
  width: 280px;
  padding: 20px;
  background-color: #fff8f0;
  border-radius: 8px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  opacity: 0;
  transition: opacity 1s ease, transform 0.8s ease;
  text-align: center;
  font-family: 'Georgia', serif;
  z-index: 1;
}

.invitation.visible {
  opacity: 1;
  transform: translateY(-50%) translateX(140px) scale(1);
}

.invitation p:first-child {
  font-weight: bold;
  font-size: 1.3rem;
  margin-bottom: 8px;
}

.invitation p:nth-child(2) {
  font-size: 1.1rem;
  color: #5a4632;
}
</style>

<script type="module">
const envelope = document.getElementById("envelope");
const container = document.getElementById("container");
const invitation = document.querySelector(".invitation");

envelope.addEventListener("click", () => {
  // Abrir la tapa
  envelope.classList.add("open");

  // Mostrar invitación después de abrir
  setTimeout(() => {
    invitation.classList.add("visible");
    container.style.opacity = "0"; // opcional si quieres desaparecer el fondo
  }, 800);
});
</script>