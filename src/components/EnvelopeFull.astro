---
// Este componente combina Envelope + FullScreenImage
---
<div class="container" id="container">
  <!-- Sobre -->
  <div class="envelope" id="envelope">
    <div class="flap"></div>
    <div class="body"></div>
  </div>

  <!-- Invitación dentro del sobre (oculta hasta abrir) -->
  <div class="invitation">
    <p>¡Nos casamos!</p>
    <p>17 de octubre de 2026</p>
  </div>
</div>

<!-- Fullscreen image con recuadro papel antiguo -->
<section class="full-image">
  <div class="image-container">
    <img src="/images/portada_invitacion.jpeg" alt="Nosotros" class="full-image-img" />

    <!-- Recuadro papel antiguo -->
    <div class="paper-note">
      <p class="title">¡NOS CASAMOS!</p>
      <p>Y queremos que nos acompañes</p>
      <p class="names"><em>Jonathan Soto y María Lince</em></p>
      <p class="date">17 de octubre de 2026</p>
    </div>
  </div>

  <!-- Overlay centrado opcional -->
  <div class="overlay">
    <h1>¡Jonathan & María!</h1>
    <p>21 de junio de 2026</p>
  </div>
</section>

<style>
/* ================= SOBRE ================= */
.container {
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f4efe6;
  transition: opacity 1s ease;
  position: relative;
}

.envelope {
  position: relative;
  width: 320px;
  height: 210px;
  cursor: pointer;
  perspective: 1200px;
  z-index: 2;
}

/* Cuerpo del sobre */
.body {
  width: 100%;
  height: 100%;
  background-image: url('/images/papel_recuadro.jpg'); /* textura de papel antiguo */
  background-size: cover;
  background-repeat: no-repeat;
  background-position: center;
  border-radius: 10px;
  box-shadow: 0 6px 15px rgba(0,0,0,0.25); /* sombra suave */
  position: relative;
  z-index: 1;
}


/* Flap del sobre */
.flap {
  position: absolute;
  top: 0;
  width: 100%;
  height: 110px;
  background-image: url('/images/papel_recuadro.jpg'); /* tapa con textura */
  background-size: cover;
  background-repeat: no-repeat;
  background-position: center;
  transform-origin: top;
  transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  clip-path: polygon(0 0, 100% 0, 50% 100%);
  box-shadow: inset 0 -4px 6px rgba(0,0,0,0.1);
  z-index: 2;
}

.envelope.open .flap {
  transform: rotateX(180deg);
}

/* Invitación dentro del sobre */
.invitation {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  width: 280px;
  padding: 20px;
  background-color: #fff8f0;
  border-radius: 8px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  opacity: 0;
  transition: opacity 1s ease, transform 0.8s ease;
  text-align: center;
  font-family: 'Georgia', serif;
  z-index: 1;
}

.invitation.visible {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.invitation p:first-child {
  font-weight: bold;
  font-size: 1.3rem;
  margin-bottom: 8px;
}

.invitation p:nth-child(2) {
  font-size: 1.1rem;
  color: #5a4632;
}

/* ================= FULLSCREEN IMAGE ================= */
.full-image {
  position: relative;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  transform: translateY(50px);
  transition: opacity 1.2s ease, transform 1.2s ease;
}

.full-image.visible {
  opacity: 1;
  transform: translateY(0);
}

.image-container {
  position: relative;
  width: 100%;
}

.full-image-img {
  width: 100%;
  height: auto;
  display: block;
}

/* Recuadro papel antiguo */
.paper-note {
  position: absolute;
  top: 15%;
  left: 50%;
  transform: translateX(-50%);
  width: 300px;
  padding: 25px 30px;
  background-image: url('/images/papel_recuadro.jpg');
  background-size: cover;
  background-repeat: no-repeat;
  background-position: center;
  color: #5a4632;
  font-family: 'Georgia', serif;
  box-shadow: 0 6px 15px rgba(0,0,0,0.3);
  border: 1px solid rgba(0,0,0,0.2);
  line-height: 1.5;
  z-index: 10;
  text-align: center;
}

.paper-note .title {
  font-weight: bold;
  font-size: 1.6rem;
  margin-bottom: 12px;
}

.paper-note .names {
  font-style: italic;
  font-size: 1.2rem;
  margin: 8px 0;
}

.paper-note .date {
  font-size: 1.1rem;
  margin-top: 8px;
}

/* Overlay */
.overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  z-index: 2;
  color: #556B2F;
  text-align: center;
  text-shadow: 0 0 8px rgba(255,255,255,0.6);
}

/* Responsive */
@media (max-width: 600px) {
  .paper-note {
    width: 220px;
    padding: 15px 18px;
  }
  .paper-note .title {
    font-size: 1.3rem;
  }
  .paper-note .names {
    font-size: 1rem;
  }
  .paper-note .date {
    font-size: 0.95rem;
  }
}
</style>

<script type="module">
const envelope = document.getElementById("envelope");
const container = document.getElementById("container");
const invitation = document.querySelector(".invitation");
const fullScreen = document.querySelector(".full-image");

envelope.addEventListener("click", () => {
  // 1️⃣ Abrir la tapa
  envelope.classList.add("open");

  // 2️⃣ Esperar animación flap
  setTimeout(() => {
    // Difuminar sobre
    container.style.opacity = "0";

    // Mostrar invitación dentro del sobre (opcional)
    if (invitation) {
      invitation.classList.add("visible");
    }

    // Mostrar Fullscreen automáticamente
    if (fullScreen) {
      fullScreen.classList.add("visible");
    }
  }, 800); // coincide con duración de flap
});
</script>