<section class="full-image">
  <div class="image-container">
  <img src="/images/portada_invitacion.jpeg" alt="Nosotros" class="full-image-img" />
      <!-- Recuadro papel antiguo -->
    <div class="paper-note">
      <p class="title">¡NOS CASAMOS!</p>
      <p>Y queremos que nos acompañes</p>
      <p class="names"><em>Jonathan Soto y María Lince</em></p>
      <p class="date">17 de octubre de 2026</p>
    </div>
  </div>
</section>

<style>
.full-image {
  position: relative;
  width: 100%;
  background-size: cover;
  background-position: center 35%; /* muestra cielo + caras */
  background-attachment: scroll; /* permite scroll normal */
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  transform: translateY(50px);
  transition: opacity 1.2s ease, transform 1.2s ease;
}
.image-container {
  position: relative;
  width: 100;
}

.full-image::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to bottom,
    rgba(255,255,255,0.6),
    rgba(255,255,255,0) 30%,
    rgba(255,255,255,0) 70%,
    rgba(255,255,255,0.6)
  );
  z-index: 1;
}

.full-image.visible {
  opacity: 1;
  transform: translateY(0);
}

.overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%,-50%);
  z-index: 2; /* sobre el degradado */
  color: #556B2F; /* verde oliva */
  text-align: center;
}
/* Recuadro tipo papel antiguo */
.paper-note {
  position: absolute;
  top: 15%; /* ajusta vertical*/
  left: 50%; /* centrado horizontal*/
  transform: translateX(-50%);/* centrado exactamente*/
  width: 300px; /* mas grande*/
  padding: 25px 30px; /* mas espacio interno*/
  background-image: url('/images/papel_textura.jpg'); /* textura de papel antiguo */
  background-size: cover;
  background-repeat: no-repeat;
  background-position: center;
  color: #000000; /* Negro */
  font-family: 'Georgia', serif;
  box-shadow: 0 4px 10px rgba(0,0,0,0.3);
  border: 1px solid rgba(0,0,0,0.2);
  line-height: 1.4;
  z-index: 10;
  text-align: center;
}

.paper-note .title {
  font-weight: bold;
  font-size: 1.6rem; /*mas grande*/
  margin-bottom: 8px;
  text-align: center;
}

.paper-note .names {
  font-style: italic;
  font-size: 1.1rem; /* mas grande*/
  text-align: center;
  margin: 6px 0;
}

.paper-note .date {
  font-size: 1.1rem; /* mas grande*/
  text-align: center;
  margin-top: 8px;
}

/* Responsive */
@media (max-width: 600px) {
  .paper-note {
    width: 220px;
    padding: 15px 18px;
  }
  .paper-note .title {
    font-size: 1.3rem;
  }
  .paper-note .date {
    font-size: 0.95rem;
  }
}


</style>

<script type="module">
const section = document.querySelector('.full-image');

function isInViewport(el) {
  const rect = el.getBoundingClientRect();
  return rect.top < window.innerHeight && rect.bottom > 0;
}

function handleScroll() {
  if (isInViewport(section)) {
    section.classList.add('visible');
    window.removeEventListener('scroll', handleScroll);
  }
}

window.addEventListener('scroll', handleScroll);
handleScroll();
</script>